{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "engineer", "client"] },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "messages": {
      "title": "Message",
      "description": "Chat messages between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "projects": {
      "title": "Project",
      "description": "Construction project details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "progress": { "type": "number" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/messages/{messageId}": {
      "schema": "messages",
      "description": "Global or direct messages"
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Construction projects"
    }
  }
}
